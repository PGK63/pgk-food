<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="pgk_food_database" />
        <exclude domain="database" path="pgk_food_database.db" />
        <exclude domain="sharedpref" path="pgk_food_secure_store.xml" />
        <exclude domain="sharedpref" path="session_secure.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="pgk_food_database" />
        <exclude domain="database" path="pgk_food_database.db" />
        <exclude domain="sharedpref" path="pgk_food_secure_store.xml" />
        <exclude domain="sharedpref" path="session_secure.xml" />
    </device-transfer>
</data-extraction-rules>
